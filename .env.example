# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Square
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key
SQUARE_ENVIRONMENT=sandbox

# Bank Transfer Details (shown to parents)
NEXT_PUBLIC_BANK_ACCOUNT_NAME=Sunrise Tennis
NEXT_PUBLIC_BANK_BSB=
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
